# ============================================
# Medicine Reminder System — Backend .env
# ============================================

# Database (MySQL)
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/mrs"

# JWT
JWT_SECRET="change-this-to-a-random-secret-string-min-32-chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV="development"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"
